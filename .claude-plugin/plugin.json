{
  "name": "@cyanheads/eurostat-mcp-server",
  "version": "0.1.12",
  "description": "Search and query 8,933 Eurostat datasets — EU economy, demography, trade, health, and NUTS regional data via MCP. STDIO or Streamable HTTP.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/eurostat-mcp-server#readme",
  "repository": "https://github.com/cyanheads/eurostat-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "@cyanheads/eurostat-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/eurostat-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
